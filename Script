-- ==================== FARM LOGIC ====================
local lastCollectionTime = tick()
local isHopping = false
local HopCooldown = 0
local PlaceID = game.PlaceId
local AllIDs = {}
local foundAnything = ""

pcall(function()
    AllIDs = game:GetService('HttpService'):JSONDecode(readfile("NotSameServers.json"))
end)
if #AllIDs == 0 then
    table.insert(AllIDs, os.date("!*t").hour)
    writefile("NotSameServers.json", game:GetService('HttpService'):JSONEncode(AllIDs))
end

local function TPReturner()
    if isHopping then return end
    isHopping = true
    local Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'))
    if Site.nextPageCursor and Site.nextPageCursor ~= "null" then
        foundAnything = Site.nextPageCursor
    end
    for _, v in pairs(Site.data) do
        if tonumber(v.playing) < tonumber(v.maxPlayers) then
            local ID = tostring(v.id)
            if not table.find(AllIDs, ID) then
                table.insert(AllIDs, ID)
                writefile("NotSameServers.json", game:GetService('HttpService'):JSONEncode(AllIDs))
                Rayfield:Notify({Title = "Server Hop", Content = "Teleporting...", Duration = 4})
                game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceID, ID, game.Players.LocalPlayer)
                wait(4)
                isHopping = false
                return
            end
        end
    end
    isHopping = false
end

spawn(function()
    while wait(10) do
        if Hop and Farm and not isHopping and tick() > HopCooldown then
            if tick() - lastCollectionTime > 30 then
                HopCooldown = tick() + 15
                pcall(TPReturner)
            end
        end
    end
end)

spawn(function()
    while true do
        wait(1)
        if Rebirth then
            local a = game.Players.LocalPlayer.PlayerGui.Gui.Buttons.Coins.Amount.Text:gsub(',', '')
            local b = game.Players.LocalPlayer.PlayerGui.Gui.Rebirth.Needed.Coins.Amount.Text:gsub(',', '')
            if tonumber(a) and tonumber(b) and tonumber(a) > tonumber(b) then
                game.ReplicatedStorage.Events.Rebirth:FireServer()
                ToolName = "Bucket"
                pcall(function() game.Players.LocalPlayer.PlayerGui.Gui.Popups.GiveReward.Visible = false end)
            end
        end
    end
end)

-- Main Farm Loop
local Character = game.Workspace:WaitForChild(game.Players.LocalPlayer.Name)
local Root = Character:WaitForChild("HumanoidRootPart")

while true do
    wait(0.15)
    if Farm then
        local Sand = nil
        local SandName = ""

        for _, v in pairs(game.Workspace.SandBlocks:GetChildren()) do
            if v:FindFirstChild("Chest") and v.CFrame.X > -40 and v.CFrame.X < 20 and v.CFrame.Z < -175 and v.CFrame.Z > -235 then
                v.CanCollide = false
                for _, part in pairs(v:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
                Sand = v
                SandName = v.Name
                break
            end
        end

        if Sand then
            pcall(function()
                if game.Players.LocalPlayer.PlayerGui.Gui.Popups.BackpackFull.Visible then
                    local OldPos = Root.CFrame
                    Root.CFrame = CFrame.new(SellX, SellY, SellZ)
                    game.ReplicatedStorage.Events.AreaSell:FireServer()
                    wait(0.45)
                    Root.CFrame = OldPos
                end

                Root.Anchored = true
                Root.CFrame = Sand.CFrame
                wait(0.25)
                Root.Anchored = false

                local tool = Character:FindFirstChild(ToolName) or game.Players.LocalPlayer.Backpack:FindFirstChild(ToolName)
                if tool then
                    Character.Humanoid:EquipTool(tool)
                    tool.RemoteClick:FireServer(game.Workspace.SandBlocks[SandName])
                end

                lastCollectionTime = tick()
            end)
        end
    end
end
