local function saveStates()
    pcall(function()
        local data = { 
            Farm = Farm or false, 
            Rebirth = Rebirth or false, 
            Hop = Hop or false,
            ToolName = ToolName,
            SellX = SellX or 3,
            SellY = SellY or 10,
            SellZ = SellZ or -160
        }
        writefile("THS_States.json", game:GetService("HttpService"):JSONEncode(data))
    end)
end

ToolInput = MainTab:CreateInput({
    Name = "Tool Name",
    CurrentValue = ToolName,
    PlaceholderText = "Bucket",
    Callback = function(Value) ToolName = Value; saveStates() end
})

MainTab:CreateButton({
    Name = "🔍 Find Current Tool",
    Callback = function()
        local player = game.Players.LocalPlayer
        local character = player.Character
        local foundTool = nil
        if character then
            for _, obj in pairs(character:GetChildren()) do
                if obj:IsA("Tool") then foundTool = obj.Name; break end
            end
        end
        if not foundTool then
            for _, tool in pairs(player.Backpack:GetChildren()) do
                if tool:IsA("Tool") then foundTool = tool.Name; break end
            end
        end
        if foundTool then
            ToolName = foundTool
            ToolInput:Set(foundTool)
            Rayfield:Notify({Title = "Tool Found", Content = foundTool, Duration = 3})
            saveStates()
        end
    end
})

